# ── Rappi MX ─────────────────────────────────────────────────────────────────
# Bearer token de autenticación de Rappi MX.
# Cómo obtenerlo: rappi.com.mx → DevTools → Network → catalog-paged/home
#                 → Request Headers → authorization (sin el prefijo "Bearer ")
# Duración: días o semanas según la sesión activa.
RAPPI_MX_TOKEN=

# ── Uber Eats MX ──────────────────────────────────────────────────────────────
# String completo de cookies de sesión de Uber Eats MX.
# Cómo obtenerlo: ubereats.com/mx → DevTools → Network → getFeedV1
#                 → Request Headers → cookie (copiar el string completo)
# Duración: ~24 horas (jwt-session expira primero).
UBER_COOKIES=
